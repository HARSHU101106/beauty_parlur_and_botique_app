# ---------------------------------------------------------------------------
# BeautyApp environment variables
# Copy this file to ".env" and fill in your real values.
# These are read by app.config.ts (Expo loads .env automatically for config).
# Do NOT commit your real .env file.
# ---------------------------------------------------------------------------

# Firebase (Project Settings -> General -> Your apps -> SDK setup & config)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Razorpay (test/live key id from the Razorpay dashboard).
# Leave blank to keep payments in placeholder mode; the app will not crash.
RAZORPAY_KEY_ID=

# Google OAuth client ids (optional – enables Google sign-in).
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
