rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Product and service images: readable by everyone, writable by admins only.
    match /products/{file=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{file=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
